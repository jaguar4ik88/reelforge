# Local scratch / reference assets (not part of the app)
tmp/

# Documentation files created by AI agents
docs/

# Node modules
node_modules/

# Environment files
.env
.env.local
.env.production

# Build outputs
dist/
build/

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed

# Coverage directory used by tools like istanbul
coverage/

# Dependency directories
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Apple Sign In key (never commit)
**/AuthKey_*.p8

# Laravel specific
/backend/vendor/
# Runtime: compiled Blade, sessions, cache (keep only .gitignore placeholders — see Laravel storage/framework/*/.gitignore)
/backend/storage/framework/views/*
!/backend/storage/framework/views/.gitignore
/backend/storage/framework/sessions/*
!/backend/storage/framework/sessions/.gitignore
/backend/storage/framework/cache/data/*
!/backend/storage/framework/cache/data/.gitignore
/backend/storage/logs/*
!/backend/storage/logs/.gitignore
# Vite build copied into public on deploy (not committed)
/backend/public/index.html
/backend/public/assets/
/backend/storage/*.key
/backend/.env
/backend/.env.backup
# Never commit — contains resolved secrets from .env (php artisan config:cache)
/backend/bootstrap/cache/config.php
/backend/.phpunit.result.cache
/backend/Homestead.json
/backend/Homestead.yaml
/backend/npm-debug.log
/backend/yarn-error.log