# Local scratch / reference assets (not part of the app)
tmp/

# Documentation files created by AI agents
docs/

# Node modules
node_modules/

# Environment files
.env
.env.local
.env.production

# Build outputs
dist/
build/

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed

# Coverage directory used by tools like istanbul
coverage/

# Dependency directories
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Apple Sign In key (never commit)
**/AuthKey_*.p8

# Laravel specific
/backend/vendor/
# Vite build copied into public on deploy (not committed)
/backend/public/index.html
/backend/public/assets/
/backend/storage/*.key
/backend/.env
/backend/.env.backup
/backend/.phpunit.result.cache
/backend/Homestead.json
/backend/Homestead.yaml
/backend/npm-debug.log
/backend/yarn-error.log