# Frontend React Standards для ReelForge

## Архитектурные принципы

- **API-first**: Вся бизнес-логика только в API, фронтенд - просто клиент
- **Никакой бизнес-логики во frontend** - только UI и взаимодействие с API
- **Подготовка к мобильной версии** - код должен быть переиспользуемым

## Структура компонентов

```jsx
// ✅ ХОРОШО - Функциональный компонент с хуками
import { useState, useEffect } from 'react';
import { api } from '../services/api';

const ProjectCard = ({ project }) => {
  const [isLoading, setIsLoading] = useState(false);
  
  const handleGenerate = async () => {
    setIsLoading(true);
    try {
      await api.generateVideo(project.id);
    } catch (error) {
      console.error('Generation failed:', error);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className="bg-white rounded-lg shadow-md p-6">
      <h3 className="text-lg font-semibold">{project.title}</h3>
      <button 
        onClick={handleGenerate}
        disabled={isLoading}
        className="mt-4 bg-blue-500 text-white px-4 py-2 rounded"
      >
        {isLoading ? 'Generating...' : 'Generate Video'}
      </button>
    </div>
  );
};
```

## API взаимодействие

```jsx
// ✅ ХОРОШО - Все через API сервис
import { api } from '../services/api';

// Используй кастомные хуки для API вызовов
const useProjects = () => {
  const [projects, setProjects] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const fetchProjects = async () => {
      try {
        const data = await api.getProjects();
        setProjects(data);
      } catch (error) {
        console.error('Failed to fetch projects:', error);
      } finally {
        setLoading(false);
      }
    };

    fetchProjects();
  }, []);

  return { projects, loading };
};

// ❌ ПЛОХО - Прямые fetch вызовы в компонентах
const Component = () => {
  useEffect(() => {
    fetch('/api/projects').then(res => res.json());
  }, []);
};
```

