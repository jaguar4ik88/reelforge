## Обработка состояний

```jsx
// ✅ ХОРОШО - Четкие состояния загрузки и ошибок
const ProjectView = ({ projectId }) => {
  const [project, setProject] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  useEffect(() => {
    const loadProject = async () => {
      try {
        setLoading(true);
        setError(null);
        const data = await api.getProject(projectId);
        setProject(data);
      } catch (err) {
        setError('Failed to load project');
      } finally {
        setLoading(false);
      }
    };

    loadProject();
  }, [projectId]);

  if (loading) return <div className="animate-pulse">Loading...</div>;
  if (error) return <div className="text-red-500">{error}</div>;
  if (!project) return <div>Project not found</div>;

  return <ProjectDetails project={project} />;
};
```

## Файловая структура

```
frontend/src/
├── components/          # Переиспользуемые компоненты
│   ├── ui/             # Базовые UI компоненты
│   └── forms/          # Формы
├── pages/              # Страницы приложения
├── layouts/            # Лейауты
├── services/           # API сервисы
├── hooks/              # Кастомные хуки
└── utils/              # Утилиты
```

## Именование

- Компоненты: `PascalCase` (ProjectCard, VideoPlayer)
- Файлы компонентов: `PascalCase.jsx` 
- Хуки: `camelCase` с префиксом `use` (useProjects, useAuth)
- Константы: `UPPER_SNAKE_CASE`
- Переменные: `camelCase`

## Производительность

```jsx
// ✅ ХОРОШО - Мемоизация тяжелых компонентов
import { memo } from 'react';

const VideoPreview = memo(({ video }) => {
  return (
    <video className="w-full h-auto" controls>
      <source src={video.url} type="video/mp4" />
    </video>
  );
});

// ✅ ХОРОШО - Debounce для поиска
import { useDebouncedCallback } from 'use-debounce';

const SearchInput = ({ onSearch }) => {
  const debouncedSearch = useDebouncedCallback(onSearch, 300);
  
  return (
    <input 
      onChange={(e) => debouncedSearch(e.target.value)}
      placeholder="Search projects..."
    />
  );
};
```