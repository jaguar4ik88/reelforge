APP_NAME=ReelForge
# Display name in UI / emails (optional; defaults to APP_NAME). Set per domain or white-label.
# REELFORGE_SITE_NAME=ReelForge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# SPA URL (OAuth redirect after Google / Apple)
FRONTEND_URL=http://localhost:5173

# ── OAuth (Google / Apple) — see docs/OAUTH_AND_EMAIL_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Cloud Console exactly (scheme + host + path). If empty, uses APP_URL + /auth/google/callback
# e.g. http://127.0.0.1:8000/auth/google/callback or https://aimaglo.com/auth/google/callback
GOOGLE_REDIRECT_URI=

APPLE_CLIENT_ID=
# Leave empty if using private key below (Socialite generates JWT secret)
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Path to AuthKey_XXX.p8 (relative to backend/ or absolute). Do not commit .p8 files.
APPLE_PRIVATE_KEY=
APPLE_PASSPHRASE=
# Must exactly match Services ID Return URLs (Apple often requires HTTPS + real domain; use ngrok/staging for local tests)
APPLE_REDIRECT_URI=

# ── Mail (registration welcome + future transactional)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=reelforge
DB_USERNAME=reelforge
DB_PASSWORD=secret

BROADCAST_DRIVER=log
# Use redis in production when available. If you set database, run migrations (includes cache table).
CACHE_DRIVER=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# S3-compatible storage (MinIO or AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=reelforge
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# FFMPEG
FFMPEG_BINARIES=/usr/bin/ffmpeg
# macOS (Homebrew): /usr/local/bin/ffmpeg or /opt/homebrew/bin/ffmpeg
# FFMPEG_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
# macOS font: /System/Library/Fonts/Supplemental/Arial Bold.ttf
FFPROBE_BINARIES=/usr/bin/ffprobe

# Plan limits
FREE_PLAN_VIDEOS_PER_MONTH=10
PRO_PLAN_VIDEOS_PER_MONTH=100

# Storage layout (paths are relative to the chosen disk root)
# Use public + php artisan storage:link for local dev, or s3/MinIO for production.
# REELFORGE_CONTENT_DISK defaults to FILESYSTEM_DISK.
# User files: {REELFORGE_USER_CONTENT_PREFIX}/{user_id}/avatars, .../projects/{id}/images, .../video.mp4
# Templates:  {REELFORGE_TEMPLATES_PATH_PREFIX}/… (e.g. templates/previews/…)
# REELFORGE_TEMPLATES_DISK defaults to REELFORGE_CONTENT_DISK.
# REELFORGE_CONTENT_DISK=
# REELFORGE_TEMPLATES_DISK=
# REELFORGE_USER_CONTENT_PREFIX=users
# REELFORGE_TEMPLATES_PATH_PREFIX=templates

# ── Payments: default FastSpring (EU/global). Ukraine → WayForPay if enabled below + WAYFORPAY_*.
# WAYFORPAY_FOR_UKRAINE_ENABLED=true
#
# ── FastSpring (credit packages: map each CreditPackage.slug to a product path in FastSpring)
# FASTSPRING_ENABLED=true
# Optional: only if FastSpring support gives a different API host (default https://api.fastspring.com).
# FASTSPRING_API_BASE_URL=https://api.fastspring.com
# FASTSPRING_API_USERNAME=
# FASTSPRING_API_PASSWORD=
# Store + checkout IDs from SpringBoard (Integrations → API / Checkout), NOT the word "popup".
# Example: yourstore/main — must match an existing checkout; "popup" is UI type, not the API id.
# Use the subdomain part only (e.g. aimaglo.test), not the full host aimaglo.test.onfastspring.com — or buyer URLs break.
# FASTSPRING_CHECKOUT_PATH=your-store-id/main
# FASTSPRING_LIVE=true
# Webhook: https://YOUR_PUBLIC_HOST/api/payments/fastspring/webhook — FastSpring cannot reach localhost; use ngrok/staging or test signature flow in SpringBoard Webhook Log.
# FASTSPRING_WEBHOOK_HMAC_SECRET=
# Append ?catalog=<FRONTEND_URL/...> so “Continue shopping” returns buyers to your app (not an auto HTTP redirect).
# FASTSPRING_APPEND_CATALOG_TO_CHECKOUT_URL=true
# FASTSPRING_CHECKOUT_RETURN_PATH=app/credits?payment=fastspring_return
# FASTSPRING_PRODUCT_TRIAL_50=
# FASTSPRING_PRODUCT_START_175=
# FASTSPRING_PRODUCT_PRO_450=
# FASTSPRING_PRODUCT_MAX_1500=
#
# ── WayForPay (UA: pay in UAH; list prices in USD — see CreditPackage seeder)
# WAYFORPAY_ENABLED=false
# WAYFORPAY_MERCHANT_ACCOUNT=
# WAYFORPAY_SECRET_KEY=
# WAYFORPAY_MERCHANT_DOMAIN_NAME=yourdomain.com
# WAYFORPAY_PAY_URL=https://secure.wayforpay.com/pay
# WAYFORPAY_USD_TO_UAH=42
# WAYFORPAY_UA_DISCOUNT_PERCENT=0

# Credits
# REELFORGE_WELCOME_CREDITS=10
# REELFORGE_DEFAULT_VIDEO_CREDIT_COST=10
# REELFORGE_CREDITS_REQUIRE_FOR_GENERATION=true
# REELFORGE_ENFORCE_MONTHLY_CAP_WITH_CREDITS=false

# ── AI Providers
REPLICATE_API_TOKEN=

# Product photo analysis (OpenAI Vision). Optional — stub if no key.
OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# Wishes → English for FLUX (fallback if Anthropic is not set)
# OPENAI_WISHES_MODEL=gpt-4o-mini

# Optional: preferred for translating / enriching user wishes (RU/UA/etc.) before Replicate.
# If empty, OPENAI_API_KEY is used for the same task.
ANTHROPIC_API_KEY=
# ANTHROPIC_WISHES_MODEL=claude-sonnet-4-20250514

# Photo-guided: call Claude/OpenAI to translate wishes to English before FLUX. Default false for MVP (English input).
# REELFORGE_WISHES_ENRICHMENT=false

# Max long edge (px) for uploaded product images after resize (GD). Saves storage / future API cost.
# REELFORGE_IMAGE_MAX_DIMENSION=1024

# Sanctum SPA / cookie sessions: hostnames only, no https:// (comma-separated).
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# CORS: full origins for the browser app, comma-separated. No trailing path slash.
# Local: http://localhost:5173
# Prod (example): https://aimaglo.com,https://www.aimaglo.com
CORS_ALLOWED_ORIGINS=http://localhost:5173
