APP_NAME=ReelForge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# SPA URL (OAuth redirect after Google / Apple)
FRONTEND_URL=http://localhost:5173

# ── OAuth (Google / Apple) — see docs/OAUTH_AND_EMAIL_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Cloud Console (use same host as APP_URL), e.g. http://127.0.0.1:8000/auth/google/callback
GOOGLE_REDIRECT_URI=

APPLE_CLIENT_ID=
# Leave empty if using private key below (Socialite generates JWT secret)
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Absolute path to AuthKey_XXX.p8 from Apple Developer
APPLE_PRIVATE_KEY=
APPLE_PASSPHRASE=
# e.g. http://127.0.0.1:8000/auth/apple/callback
APPLE_REDIRECT_URI=

# ── Mail (registration welcome + future transactional)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=reelforge
DB_USERNAME=reelforge
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# S3-compatible storage (MinIO or AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=reelforge
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# FFMPEG
FFMPEG_BINARIES=/usr/bin/ffmpeg
# macOS (Homebrew): /usr/local/bin/ffmpeg or /opt/homebrew/bin/ffmpeg
# FFMPEG_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
# macOS font: /System/Library/Fonts/Supplemental/Arial Bold.ttf
FFPROBE_BINARIES=/usr/bin/ffprobe

# Plan limits
FREE_PLAN_VIDEOS_PER_MONTH=10
PRO_PLAN_VIDEOS_PER_MONTH=100

# Storage layout (paths are relative to the chosen disk root)
# Use public + php artisan storage:link for local dev, or s3/MinIO for production.
# REELFORGE_CONTENT_DISK defaults to FILESYSTEM_DISK.
# User files: {REELFORGE_USER_CONTENT_PREFIX}/{user_id}/avatars, .../projects/{id}/images, .../video.mp4
# Templates:  {REELFORGE_TEMPLATES_PATH_PREFIX}/… (e.g. templates/previews/…)
# REELFORGE_TEMPLATES_DISK defaults to REELFORGE_CONTENT_DISK.
# REELFORGE_CONTENT_DISK=
# REELFORGE_TEMPLATES_DISK=
# REELFORGE_USER_CONTENT_PREFIX=users
# REELFORGE_TEMPLATES_PATH_PREFIX=templates

# Credits
# REELFORGE_WELCOME_CREDITS=50
# REELFORGE_DEFAULT_VIDEO_CREDIT_COST=10
# REELFORGE_CREDITS_REQUIRE_FOR_GENERATION=true
# REELFORGE_ENFORCE_MONTHLY_CAP_WITH_CREDITS=false

SANCTUM_STATEFUL_DOMAINS=localhost:5173

CORS_ALLOWED_ORIGINS=http://localhost:5173
