APP_NAME=App
# Display name in UI / emails (optional; defaults to APP_NAME). Set per domain or white-label.
# APP_PLATFORM_SITE_NAME=My Brand
# Legacy: REELFORGE_SITE_NAME (still read if set)
#
# Seller / legal entity (shown on site footer + /contacts) — WayForPay & UA consumer law. Leave empty to hide.
# Use double quotes if a value contains spaces or special characters.
# SELLER_COMPANY_NAME=
# SELLER_TAX_ID=
# SELLER_LEGAL_ADDRESS="City, Country"
# SELLER_PHYSICAL_ADDRESS=
# SELLER_PHONE="+380000000000"
# SELLER_EMAIL=
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# SPA URL (OAuth redirect after Google / Apple). Required for local dev (Vite :5173 vs API :8000).
# Production: set to public site URL (e.g. https://aimaglo.com). If omitted, config falls back to APP_URL.
FRONTEND_URL=http://localhost:5173

# New signups (POST /api/auth/register + OAuth new users). false = only existing users can sign in.
# APP_PLATFORM_REGISTRATION_ENABLED=true

# ── OAuth (Google / Apple) — see docs/OAUTH_AND_EMAIL_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Cloud Console exactly (scheme + host + path). If empty, uses APP_URL + /auth/google/callback
# e.g. http://127.0.0.1:8000/auth/google/callback or https://aimaglo.com/auth/google/callback
GOOGLE_REDIRECT_URI=

APPLE_CLIENT_ID=
# Leave empty if using private key below (Socialite generates JWT secret)
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Path to AuthKey_XXX.p8 (relative to backend/ or absolute). Do not commit .p8 files.
APPLE_PRIVATE_KEY=
APPLE_PASSPHRASE=
# Must exactly match Services ID Return URLs (Apple often requires HTTPS + real domain; use ngrok/staging for local tests)
APPLE_REDIRECT_URI=

# ── Mail (registration welcome + future transactional)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

BROADCAST_DRIVER=log
# Use redis in production when available. If you set database, run migrations (includes cache table).
CACHE_DRIVER=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# S3-compatible storage (MinIO or AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-bucket
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# FFMPEG
FFMPEG_BINARIES=/usr/bin/ffmpeg
# macOS (Homebrew): /usr/local/bin/ffmpeg or /opt/homebrew/bin/ffmpeg
# FFMPEG_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
# macOS font: /System/Library/Fonts/Supplemental/Arial Bold.ttf
FFPROBE_BINARIES=/usr/bin/ffprobe

# Plan limits
FREE_PLAN_VIDEOS_PER_MONTH=10
PRO_PLAN_VIDEOS_PER_MONTH=100

# Storage layout (paths are relative to the chosen disk root)
# Use public + php artisan storage:link for local dev, or s3/MinIO for production.
# APP_PLATFORM_CONTENT_DISK (legacy REELFORGE_CONTENT_DISK) defaults to FILESYSTEM_DISK.
# User files: {APP_PLATFORM_USER_CONTENT_PREFIX}/…
# APP_PLATFORM_TEMPLATES_DISK= (second fallback: same as content disk)
# APP_PLATFORM_USER_CONTENT_PREFIX=users
# APP_PLATFORM_TEMPLATES_PATH_PREFIX=templates

# ── Payments: default FastSpring (EU/global). Ukraine → WayForPay if enabled below + WAYFORPAY_*.
# Set WAYFORPAY_BILLING_GLOBAL=true to use WayForPay for all regions (WayForPay-only).
# WAYFORPAY_BILLING_GLOBAL=false
# WAYFORPAY_FOR_UKRAINE_ENABLED=true
#
# ── FastSpring (credit packages: map each CreditPackage.slug to a product path in FastSpring)
# FASTSPRING_ENABLED=true
# Optional: only if FastSpring support gives a different API host (default https://api.fastspring.com).
# FASTSPRING_API_BASE_URL=https://api.fastspring.com
# FASTSPRING_API_USERNAME=
# FASTSPRING_API_PASSWORD=
# Store + checkout IDs from SpringBoard (Integrations → API / Checkout), NOT the word "popup".
# Example: yourstore/main — must match an existing checkout; "popup" is UI type, not the API id.
# Use the subdomain part only (e.g. aimaglo.test), not the full host aimaglo.test.onfastspring.com — or buyer URLs break.
# FASTSPRING_CHECKOUT_PATH=your-store-id/main
# FASTSPRING_LIVE=true
# Webhook: https://YOUR_PUBLIC_HOST/api/payments/fastspring/webhook — FastSpring cannot reach localhost; use ngrok/staging or test signature flow in SpringBoard Webhook Log.
# FASTSPRING_WEBHOOK_HMAC_SECRET=
# Append ?catalog=<FRONTEND_URL/...> so “Continue shopping” returns buyers to your app (not an auto HTTP redirect).
# FASTSPRING_APPEND_CATALOG_TO_CHECKOUT_URL=true
# FASTSPRING_CHECKOUT_RETURN_PATH=app/credits?payment=fastspring_return
# FASTSPRING_PRODUCT_TRIAL_50=
# FASTSPRING_PRODUCT_START_175=
# FASTSPRING_PRODUCT_PRO_450=
# FASTSPRING_PRODUCT_MAX_1500=
#
# ── WayForPay (UA: pay in UAH; list prices in USD — see CreditPackage seeder)
# WAYFORPAY_ENABLED=false
# WAYFORPAY_MERCHANT_ACCOUNT=
# WAYFORPAY_SECRET_KEY=
# WAYFORPAY_MERCHANT_DOMAIN_NAME=yourdomain.com
# WAYFORPAY_PAY_URL=https://secure.wayforpay.com/pay
# WAYFORPAY_USD_TO_UAH=42
# WAYFORPAY_UA_DISCOUNT_PERCENT=0

# Credits (env keys: APP_PLATFORM_* — legacy REELFORGE_* still work)
# APP_PLATFORM_WELCOME_CREDITS=10
# APP_PLATFORM_DEFAULT_VIDEO_CREDIT_COST=10
# Product card: 2 for «by example» (GPT Image + reference), 1 for prompt / photo-guided card.
# APP_PLATFORM_CARD_BY_EXAMPLE_CREDITS=2
# APP_PLATFORM_CARD_BY_PROMPT_CREDITS=1
# APP_PLATFORM_CREDITS_REQUIRE_FOR_GENERATION=true
# APP_PLATFORM_ENFORCE_MONTHLY_CAP_WITH_CREDITS=false
# Photo-flow «Video» tab: min balance and blocked plan slugs
# APP_PLATFORM_PHOTO_GUIDED_VIDEO_MIN_BALANCE=10
# APP_PLATFORM_PHOTO_GUIDED_VIDEO_BLOCKED_PLANS=starter-monthly

# ── AI Providers
REPLICATE_API_TOKEN=

# Product card: new pipeline (Kontext → vision → PHP text) when true. Tuning: config/platform.php card.php_composite (no extra CARD_* env vars).
# APP_PLATFORM_CARD_PHP_COMPOSITE=false
#
# Card typography via Puppeteer + HTML templates (requires: cd backend/card-renderer && npm install).
# APP_PLATFORM_CARD_PUPPETEER=false
# APP_PLATFORM_NODE_BINARY=node
# Optional system Chrome (puppeteer-core style): PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# APP_PLATFORM_CARD_PUPPETEER_CLI=
# APP_PLATFORM_CARD_PUPPETEER_DPR=2
# APP_PLATFORM_CARD_PUPPETEER_JPEG_QUALITY=92

# Product photo analysis (OpenAI Vision). Optional — stub if no key.
OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# Infographic layout command (`infographic:generate-layout`): use gpt-4o if mini misses text regions.
# Wishes → English for FLUX (fallback if Anthropic is not set)
# OPENAI_WISHES_MODEL=gpt-4o-mini
# Product card «by example»: OpenAI Images /edits (gpt-image-1.5 — two inputs: product + layout reference)
# OPENAI_GPT_IMAGE_MODEL=gpt-image-1.5
# OPENAI_GPT_IMAGE_QUALITY=medium
# OPENAI_GPT_IMAGE_INPUT_FIDELITY=high

# Optional: preferred for translating / enriching user wishes (RU/UA/etc.) before Replicate.
# If empty, OPENAI_API_KEY is used for the same task.
ANTHROPIC_API_KEY=
# ANTHROPIC_WISHES_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022
# Card pre-analysis: OpenAI only if this is true; false = Anthropic only (no OpenAI fallback)
# APP_PLATFORM_CARD_ANALYSIS_OPENAI_FALLBACK

# Photo-guided: translate wishes to English before FLUX. Default false.
# APP_PLATFORM_WISHES_ENRICHMENT=false

# Photo-flow Video tab: Replicate I2V model version (see Replicate model API for current hash)
# APP_PLATFORM_VIDEO_I2V_MODEL=…
# APP_PLATFORM_VIDEO_I2V_FRAMES=25
# APP_PLATFORM_VIDEO_I2V_STEPS=25
# APP_PLATFORM_VIDEO_I2V_WIDTH=0
# APP_PLATFORM_VIDEO_I2V_HEIGHT=0

# Max long edge (px) for uploaded product images (GD)
# APP_PLATFORM_IMAGE_MAX_DIMENSION=1024

# Sanctum SPA / cookie sessions: hostnames only, no https:// (comma-separated).
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# CORS: full origins for the browser app, comma-separated. No trailing path slash.
# Local: http://localhost:5173
# Prod (example): https://aimaglo.com,https://www.aimaglo.com
CORS_ALLOWED_ORIGINS=http://localhost:5173
