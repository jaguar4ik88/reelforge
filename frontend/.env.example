# Same origin as Laravel APP_URL (no /api suffix; trailing slash is OK, stripped at build).
# Omit on production if the SPA and API are served from the same origin → axios uses /api (no CORS).
# Must match backend APP_URL host (localhost vs 127.0.0.1 are different for OAuth)
VITE_API_URL=http://localhost:8000

# Canonical site URL for SEO (Open Graph, JSON-LD, canonical links). Omit in dev → window.location.origin.
# VITE_SITE_URL=https://reelforge.com

# Fallback display name until GET /api/site loads (should match backend REELFORGE_SITE_NAME / APP_NAME).
# VITE_SITE_NAME=ReelForge


# Optional: absolute URL to a 1200×630 image for og:image / Twitter Card (before/after style works well).
# VITE_OG_IMAGE_URL=https://reelforge.store/og-image.jpg
